# lithium-vault-mcp configuration
# The MCP server pays the vault's x402 fee from YOUR OWN wallet (Model A: bring-your-own-wallet).
# In Claude Desktop / Claude Code, set these in the MCP server's `env` block rather than a .env file.

# --- Your Coinbase CDP wallet (the wallet that pays the per-call USDC fee) ---
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# Named CDP account to pay from (created automatically if it doesn't exist).
CDP_ACCOUNT_NAME=lithium-vault-mcp

# --- Vault endpoint (override only for testing) ---
VAULT_BASE_URL=https://clink-lithium-vault.fly.dev

# --- Safety guard: never pay more than this many USDC for a single call ---
# Story tier is $0.20, so 0.25 leaves headroom while blocking any runaway charge.
X402_MAX_PRICE=0.25
